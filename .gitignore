# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.local
*.swp
*.swo
*~
*.secret.*
credentials.*
secrets.*
*.key
*.cert

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env*
!.env.example

# vercel
.vercel

# IDE / editor
.vscode/
.idea/
.history/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# temp
tmp/
temp/
.tmp/

# typescript
*.tsbuildinfo
next-env.d.ts
